# Discord bot (required for the bot only)
DISCORD_TOKEN=
# Channel ID for proactive alert posts (0 = disabled)
ALERT_CHANNEL_ID=0
# Where the bot finds the backend
BACKEND_URL=http://127.0.0.1:8000

# Optional: LLM-polished bot replies
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Demo helpers
# SIM_CLOCK_OFFSET_HOURS=13   # pretend it is night to show after-hours alerts
# SEED_ALERT_DEMO=0           # disable the seeded 2-hour alert
